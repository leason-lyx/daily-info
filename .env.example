# Docker Compose deployment
# SQLite is stored in the /data volume inside the api/worker/scheduler containers.
DATABASE_URL=sqlite:////data/daily-info.db
PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://api:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# RSSHub
RSSHUB_PUBLIC_INSTANCES=https://rsshub.rssforever.com,https://rsshub.ktachibana.party,https://rsshub.cups.moe,https://rsshub-balancer.virworks.moe
RSSHUB_SELF_HOSTED_BASE_URL=

# Optional outbound proxy for backend containers.
# The default Compose backend uses host networking, so localhost points at the host.
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1,::1,api,web,worker,scheduler,rsshub,host.docker.internal

# Initial OpenAI-compatible summary provider (optional). More custom API
# profiles can be managed in Settings after startup.
LLM_PROVIDER_TYPE=none
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL_NAME=
LLM_TEMPERATURE=0.2
LLM_TIMEOUT=60

# Codex CLI summary provider (optional)
CODEX_CLI_PATH=codex
CODEX_CLI_MODEL=
